  @@index([created_by], map: "fk_tb_financeiro_tb_usuario1_idx")
}

model tb_funcionario {
  id_funcionario   BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  id_unidade       BigInt           @db.UnsignedBigInt
  id_pessoa_fisica BigInt           @db.UnsignedBigInt
  tb_caixa         tb_caixa[]
  tb_pessoa_fisica tb_pessoa_fisica @relation(fields: [id_pessoa_fisica], references: [id_pessoa_fisica], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_funcionario_tb_pessoa_fisica1")
  tb_unidade       tb_unidade       @relation(fields: [id_unidade], references: [id_unidade], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_funcionario_tb_unidade1")
  tb_funcionario_unidade tb_funcionario_unidade[]

