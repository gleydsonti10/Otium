  tb_parceiro      tb_parceiro[]
  tb_unidade       tb_unidade[]

  @@index([id_cidade], map: "fk_tb_endereco_tb_cidade1_idx")
}

model tb_especialidade {
  codigo_especialidade Int               @id @unique(map: "codigo_UNIQUE") @db.UnsignedInt
