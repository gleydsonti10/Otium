generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model keys {
  id             Int        @id @default(autoincrement())
  key            String     @db.VarChar(40)
  level          Int
  ignore_limits  Boolean    @default(false)
  date_created   Int
  last_action    DateTime   @default(now()) @db.DateTime(0)
  is_private_key Boolean    @default(false)
  ip_addresses   String?    @db.Text
  user_id        BigInt     @db.UnsignedBigInt
  id_role        BigInt     @db.UnsignedBigInt
  tb_role        tb_role    @relation(fields: [id_role], references: [id_role], onDelete: NoAction, onUpdate: NoAction, map: "fk_keys_tb_role1")
  tb_usuario     tb_usuario @relation(fields: [user_id], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "fk_keys_tb_usuario1")

  @@index([id_role], map: "fk_keys_tb_role1_idx")
  @@index([user_id], map: "fk_keys_tb_usuario1_idx")
}

model limits {
  id           Int    @id @default(autoincrement())
  uri          String @db.VarChar(255)
  count        Int
  hour_started Int
  api_key      String @db.VarChar(40)
}

model logs {
  id            Int     @id @default(autoincrement())
  uri           String  @db.VarChar(255)
  method        String  @db.VarChar(6)
  params        String? @db.Text
  api_key       String  @db.VarChar(40)
  ip_address    String  @db.VarChar(45)
  time          Int
  rtime         Float?  @db.Float
  authorized    String  @db.VarChar(1)
  response_code Int?    @default(0) @db.SmallInt
}

model tb_agendamento {
  id_agendamento                                    BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  codigo                                            String?                       @unique(map: "codigo_UNIQUE") @db.VarChar(45)
  status                                            tb_agendamento_status         @default(pendente)
  representante_pago                                Boolean?                      @default(false)
  data_realizacao                                   DateTime?                     @db.DateTime(0)
  data_modificacao                                  DateTime?                     @db.DateTime(0)
  data_criacao                                      DateTime                      @default(now()) @db.DateTime(0)
  id_cliente                                        BigInt                        @db.UnsignedBigInt
  id_parceiro                                       BigInt                        @db.UnsignedBigInt
  id_financeiro                                     BigInt?                       @db.UnsignedBigInt
  id_agendamento_pagamento                          BigInt?                       @db.UnsignedBigInt
  id_representante                                  BigInt?                       @db.UnsignedBigInt
  id_representante_pagamento                        BigInt?                       @db.UnsignedBigInt
  created_by                                        BigInt                        @db.UnsignedBigInt
  modified_by                                       BigInt?                       @db.UnsignedBigInt
  tb_agendamento_pagamento                          tb_agendamento_pagamento?     @relation(fields: [id_agendamento_pagamento], references: [id_agendamento_pagamento], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_tb_agendamento_pagamento1")
  tb_cliente                                        tb_cliente                    @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_tb_cliente1")
  tb_financeiro                                     tb_financeiro?                @relation(fields: [id_financeiro], references: [id_financeiro], onUpdate: NoAction, map: "fk_tb_agendamento_tb_financeiro1")
  tb_parceiro                                       tb_parceiro                   @relation(fields: [id_parceiro], references: [id_parceiro], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_tb_parceiro1")
  tb_representante                                  tb_representante?             @relation(fields: [id_representante], references: [id_representante], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_tb_representante1")
  tb_representante_pagamento                        tb_representante_pagamento?   @relation(fields: [id_representante_pagamento], references: [id_representante_pagamento], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_tb_representante_pagamento1")
  tb_usuario_tb_agendamento_created_byTotb_usuario  tb_usuario                    @relation("tb_agendamento_created_byTotb_usuario", fields: [created_by], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_tb_usuario1")
  tb_usuario_tb_agendamento_modified_byTotb_usuario tb_usuario?                   @relation("tb_agendamento_modified_byTotb_usuario", fields: [modified_by], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_tb_usuario2")
  tb_agendamento_procedimento                       tb_agendamento_procedimento[]
  tb_movimento                                      tb_movimento[]

  @@index([id_agendamento_pagamento], map: "fk_tb_agendamento_tb_agendamento_pagamento1_idx")
  @@index([id_cliente], map: "fk_tb_agendamento_tb_cliente1_idx")
  @@index([id_financeiro], map: "fk_tb_agendamento_tb_financeiro1_idx")
  @@index([id_parceiro], map: "fk_tb_agendamento_tb_parceiro1_idx")
  @@index([id_representante], map: "fk_tb_agendamento_tb_representante1_idx")
  @@index([id_representante_pagamento], map: "fk_tb_agendamento_tb_representante_pagamento1_idx")
  @@index([created_by], map: "fk_tb_agendamento_tb_usuario1_idx")
  @@index([modified_by], map: "fk_tb_agendamento_tb_usuario2_idx")
}

model tb_agendamento_pagamento {
  id_agendamento_pagamento       BigInt                         @id @default(autoincrement())
  tipo                           tb_agendamento_pagamento_tipo? @default(entrada)
  descricao                      String?                        @db.VarChar(255)
  valor_pago_cartao              Decimal                        @default(0.00) @db.Decimal(9, 2)
  valor_pago_especie             Decimal                        @default(0.00) @db.Decimal(9, 2)
  valor_pago_pix                 Decimal                        @default(0.00) @db.Decimal(9, 2)
  valor_adicional_cartao         Decimal                        @default(0.00) @db.Decimal(9, 2)
  valor_representante            Decimal                        @default(0.00) @db.Decimal(9, 2)
  valor_troco                    Decimal                        @default(0.00) @db.Decimal(9, 2)
  id_caixa                       BigInt                         @db.UnsignedBigInt
  parent_agendamento_pagamento   BigInt?                        @db.UnsignedBigInt
  data_criacao                   DateTime?                      @default(now()) @db.DateTime(0)
  tb_agendamento                 tb_agendamento[]
  tb_caixa                       tb_caixa                       @relation(fields: [id_caixa], references: [id_caixa], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_caixa_tb_caixa1")
  tb_agendamento_pagamento       tb_agendamento_pagamento?      @relation("tb_agendamento_pagamentoTotb_agendamento_pagamento", fields: [parent_agendamento_pagamento], references: [id_agendamento_pagamento], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_pagamento_tb_agendamento_pagamento1")
  other_tb_agendamento_pagamento tb_agendamento_pagamento[]     @relation("tb_agendamento_pagamentoTotb_agendamento_pagamento")

  @@index([id_caixa], map: "fk_tb_agendamento_caixa_tb_caixa1_idx")
  @@index([parent_agendamento_pagamento], map: "fk_tb_agendamento_pagamento_tb_agendamento_pagamento1_idx")
}

model tb_agendamento_procedimento {
  id_agendamento           BigInt                   @db.UnsignedBigInt
  id_parceiro_procedimento BigInt                   @db.UnsignedBigInt
  quantidade               Int
  status                   Int                      @default(1) @db.TinyInt
  desconto                 Decimal                  @default(0.00) @db.Decimal(9, 2)
  data_criacao             DateTime                 @default(now()) @db.DateTime(0)
  data_modificacao         DateTime?                @db.DateTime(0)
  tb_agendamento           tb_agendamento           @relation(fields: [id_agendamento], references: [id_agendamento], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_procedimento_tb_agendamento1")
  tb_parceiro_procedimento tb_parceiro_procedimento @relation(fields: [id_parceiro_procedimento], references: [id_parceiro_procedimento], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_agendamento_procedimento_tb_parceiro_procedimento1")

  @@id([id_agendamento, id_parceiro_procedimento])
  @@index([id_parceiro_procedimento], map: "fk_tb_agendamento_procedimento_tb_parceiro_procedimento1_idx")
}

model tb_caixa {
  id_caixa                 BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  valor_abertura           Decimal                    @db.Decimal(9, 2)
  valor_fechamento         Decimal?                   @db.Decimal(9, 2)
  total_cartao             Decimal?                   @db.Decimal(9, 2)
  total_pix                Decimal?                   @db.Decimal(9, 2)
  data_abertura            DateTime                   @default(now()) @db.DateTime(0)
  data_fechamento          DateTime?                  @db.DateTime(0)
  id_funcionario           BigInt?                    @db.UnsignedBigInt
  id_usuario               BigInt                     @db.UnsignedBigInt
  tb_agendamento_pagamento tb_agendamento_pagamento[]
  tb_funcionario           tb_funcionario?            @relation(fields: [id_funcionario], references: [id_funcionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_caixa_tb_funcionario1")
  tb_usuario               tb_usuario                 @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_caixa_tb_usuario1")

  @@index([id_funcionario], map: "fk_tb_caixa_tb_funcionario1_idx")
  @@index([id_usuario], map: "fk_tb_caixa_tb_usuario1_idx")
}

model tb_cidade {
  id_cidade   Int           @id @db.UnsignedInt
  nome        String        @db.VarChar(50)
  uf          String        @db.Char(2)
  tb_endereco tb_endereco[]
}

model tb_cliente {
  id_cliente           BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  foto                 String?                @db.VarChar(255)
  data_criacao         DateTime               @default(now()) @db.DateTime(0)
  data_modificacao     DateTime?              @db.DateTime(0)
  status               Int                    @default(1) @db.TinyInt
  id_pessoa_fisica     BigInt                 @db.UnsignedBigInt
  id_endereco          BigInt                 @db.UnsignedBigInt
  created_by           BigInt                 @db.UnsignedBigInt
  tb_agendamento       tb_agendamento[]
  tb_endereco          tb_endereco            @relation(fields: [id_endereco], references: [id_endereco], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_cliente_tb_endereco1")
  tb_pessoa_fisica     tb_pessoa_fisica       @relation(fields: [id_pessoa_fisica], references: [id_pessoa_fisica], onDelete: Cascade, onUpdate: NoAction, map: "fk_tb_cliente_tb_pessoa_fisica1")
  tb_usuario           tb_usuario             @relation(fields: [created_by], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "fk_tb_cliente_tb_usuario1")
  tb_cliente_documento tb_cliente_documento[]

  @@index([id_endereco], map: "fk_tb_cliente_tb_endereco1_idx")
  @@index([id_pessoa_fisica], map: "fk_tb_cliente_tb_pessoa_fisica1_idx")
  @@index([created_by], map: "fk_tb_cliente_tb_usuario1_idx")
}

model tb_cliente_documento {
  id_cliente   BigInt       @db.UnsignedBigInt
  id_documento BigInt       @db.UnsignedBigInt
  tb_cliente   tb_cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_cliente_has_tb_documento_tb_cliente1")
  tb_documento tb_documento @relation(fields: [id_documento], references: [id_documento], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_cliente_has_tb_documento_tb_documento1")

  @@id([id_cliente, id_documento])
  @@index([id_cliente], map: "fk_tb_cliente_has_tb_documento_tb_cliente1_idx")
  @@index([id_documento], map: "fk_tb_cliente_has_tb_documento_tb_documento1_idx")
}

model tb_documento {
  id_documento          BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  nome                  String                  @db.VarChar(90)
  path                  String                  @db.VarChar(255)
  descricao             String?                 @db.VarChar(255)
  tipo                  String                  @db.VarChar(45)
  data_criacao          DateTime                @default(now()) @db.DateTime(0)
  data_modificacao      DateTime?               @db.DateTime(0)
  tb_cliente_documento  tb_cliente_documento[]
  tb_parceiro_documento tb_parceiro_documento[]
