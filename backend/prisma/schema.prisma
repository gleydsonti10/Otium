  data_modificacao DateTime?            @db.DateTime(0)
  id_parceiro      BigInt               @db.UnsignedBigInt
  created_by       BigInt?              @db.UnsignedBigInt
  tb_agendamento   tb_agendamento[]
  tb_parceiro      tb_parceiro          @relation(fields: [id_parceiro], references: [id_parceiro], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_financeiro_tb_parceiro1")
  tb_usuario       tb_usuario?          @relation(fields: [created_by], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_financeiro_tb_usuario1")

