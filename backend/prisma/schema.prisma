model tb_menu_role {
  id_menu BigInt  @db.UnsignedBigInt
  id_role BigInt  @db.UnsignedBigInt
  tb_menu tb_menu @relation(fields: [id_menu], references: [id_menu], onDelete: NoAction, onUpdate: NoAction, map: "fk_tb_menu_has_tb_role_tb_menu1")
